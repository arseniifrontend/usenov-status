{
    "compilerOptions": {
        "target": "ES2020",
        "module": "ESNext",
        "jsx": "react-jsx",
        "moduleResolution": "Bundler",
    
        "strict": true,
        "declaration": true,
        "declarationMap": true,
    
        "skipLibCheck": true,
        "isolatedModules": true
    },
    "include": ["src"]
}